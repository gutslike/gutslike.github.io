---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
			<main>
				<section>
					<h1>Manubhav Sharma</h1>

					<p>
						Computer Science (AI) student, builder, and lifelong learner exploring
						the intersection of artificial intelligence, software engineering,
						and scalable systems.
					</p>

					<p>
						I use this space to document what I learn, build projects publicly,
						and break down concepts into structured notes and guides.
					</p>
				</section>

				<section>
					<h2>About Me</h2>

					<p>
						I am currently pursuing a degree in Computer Science with a focus on AI.
						My interests span machine learning, software architecture,
						system design, and solving engineering problems through code.
					</p>

					<p>
						I enjoy turning complex ideas into practical systems and sharing
						the process openly through projects and technical writing.
					</p>
				</section>

				<section>
					<h2>What I Work On</h2>

					<ul>
						<li>Artificial Intelligence & Machine Learning</li>
						<li>Software Engineering</li>
						<li>System Design</li>
						<li>Full Stack Development</li>
						<li>Performance Focused Problem Solving</li>
					</ul>
				</section>

				<section>
					<h2>Current Focus Areas</h2>

					<ul>
						<li>Deep Learning & Neural Networks</li>
						<li>Building AI-powered applications</li>
						<li>Data Structures & Algorithms</li>
						<li>Distributed Systems</li>
						<li>Developer Productivity Systems</li>
					</ul>
				</section>

				<section>
					<h2>Featured Projects</h2>

					<ul>
						<li>FIR Classification System using NLP and Deep Learning</li>
						<li>Collaborative Team Management Platform</li>
						<li>Bluetooth Data Streaming & Graphing App</li>
						<li>Expense Tracking Platform</li>
					</ul>
				</section>

				<section>
					<h2>Why This Blog Exists</h2>

					<p>
						This website is my knowledge base — a place where I document concepts,
						project learnings, experiments, failures, and technical explorations.
					</p>

					<p>
						If something helped me understand a topic better,
						it will probably end up here.
					</p>
				</section>
			</main>
		<Footer />
	</body>
</html>
